string memory) {         return _name.toStringWithFallback(_nameFallback);     } } ```\",\"kind\":\"dev\",\"methods\":{},\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{},\"version\":1}},\"settings\":{\"compilationTarget\":{\"@openzeppelin/contracts/utils/ShortStrings.sol\":\"ShortStrings\"},\"evmVersion\":\"paris\",\"libraries\":{},\"metadata\":{\"appendCBOR\":false,\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[],\"viaIR\":true},\"sources\":{\"@openzeppelin/contracts/utils/ShortStrings.sol\":{\"keccak256\":\"0x1c81b6c33aedd17e6c66fbc435a8e7b3e777deb17aa413413994d8420a4d9faa\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://a11d6ffc8319a512bf63dba12b7462579523870f9d217d48897e391bef8d2cbf\",\"dweb:/ipfs/QmWzvMN1qs42HatbwFmxoMsGtoqj45PMbqGaDBk6f6AQtL\"]},\"@openzeppelin/contracts/utils/StorageSlot.sol\":{\"keccak256\":\"0x8f367ba298ab95962fff5f92ce15e8b4e9979430d5338cc8a5dcbe06fbf3bf51\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://19c7ce43eb9a011f224126a914f814b18ee8b6dd242ce130e3ee211d3f0a8cd5\",\"dweb:/ipfs/Qmf6SWNJ5SAsn5k8uYqNkGTTQUUFq7P6ZA6aTS6xmVpjqp\"]}},\"version\":1}"}},"@openzeppelin/contracts/utils/StorageSlot.sol":{"StorageSlot":{"evm":{"bytecode":{"functionDebugData":{},"generatedSources":[],"linkReferences":{},"object":"608080604052346018575b60049081601e823930815050f35b600080fdfe600080fd","opcodes":"PUSH1 0x80 DUP1 PUSH1 0x40 MSTORE CALLVALUE PUSH1 0x18 JUMPI JUMPDEST PUSH1 0x4 SWAP1 DUP2 PUSH1 0x1E DUP3 CODECOPY ADDRESS DUP2 POP POP RETURN JUMPDEST PUSH1 0x0 DUP1 REVERT INVALID PUSH1 0x0 DUP1 REVERT ","sourceMap":"1407:2774:24:-:0;;;;;;;-1:-1:-1;1407:2774:24;;;;;;;;;;;;;;"},"deployedBytecode":{"functionDebugData":{},"generatedSources":[],"immutableReferences":{},"linkReferences":{},"object":"600080fd","opcodes":"PUSH1 0x0 DUP1 REVERT ","sourceMap":"1407:2774:24:-:0;;"},"legacyAssembly":{".code":[{"begin":1407,"end":4181,"name":"PUSH","source":24,"value":"80"},{"begin":1407,"end":4181,"name":"DUP1","source":24
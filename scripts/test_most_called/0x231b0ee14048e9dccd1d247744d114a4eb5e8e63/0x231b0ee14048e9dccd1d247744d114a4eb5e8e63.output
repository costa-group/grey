rd, the CNAME, then the second A record which would overwrite the first.\"},\"setZonehash(bytes32,bytes)\":{\"notice\":\"setZonehash sets the hash for the zone. May only be called by the owner of that node in the ENS registry.\"},\"zonehash(bytes32)\":{\"notice\":\"zonehash obtains the hash for the zone.\"}},\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/resolvers/profiles/DNSResolver.sol\":\"DNSResolver\"},\"evmVersion\":\"london\",\"libraries\":{},\"metadata\":{\"appendCBOR\":false,\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[],\"viaIR\":true},\"sources\":{\"@ensdomains/buffer/contracts/Buffer.sol\":{\"keccak256\":\"0xcaa388dc1e3e52a8afec233b0667f8811478098047cf1e639cbd299b8a9844db\",\"license\":\"BSD-2-Clause\",\"urls\":[\"bzz-raw://8be38398fba88ff44136df78c1d33e4f2438828400e6b55aff2b55c327d57e21\",\"dweb:/ipfs/QmNsaipVnzonXr8i2QcHSAT85XM29zrAe5uuqXmccTqQpc\"]},\"@openzeppelin/contracts/utils/introspection/ERC165.sol\":{\"keccak256\":\"0x81155bc66870ba0deb5b37643343a0aec3a1971483f44453a1de38fc8400a68f\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://934e419e83abace9c288ca8ea11dd36bf6d73a867cf4f07a456c10b05458f24e\",\"dweb:/ipfs/QmQtYfviSp3BSLA2mSFYTA4uBWfVq8w1cSo9wiwZqBpp1z\"]},\"@openzeppelin/contracts/utils/introspection/IERC165.sol\":{\"keccak256\":\"0x869e83886c5b0807e70fd5d0bebb817aa042a96bf2951bd830f616eb97d5d209\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://87690834a753562ce6abd969ede3856cebe0321a008b6eba2aca81654d845f32\",\"dweb:/ipfs/QmcKjFhQJejQLc9EGKJtgj2ZtVf7vwBQscsqQCzjaNP8gh\"]},\"contracts/dnssec-oracle/BytesUtils.sol\":{\"keccak256\":\"0xdacd3e4a461f64e0c87b3dd4ac31efef2013a86828e97aedc4aa70e09f3e0cdc\",\"urls\":[\"bzz-raw://2a888cf3a273dc5797f2681d9590bf8b5f3d253390e1713d5e52e0996c385545\",\"dweb:/ipfs/QmbzZeBUCv6netWKfpHa8gcdrTXY8SeGs9u7Nr349uA85z\"]},\"contracts/dnssec-oracle/RRUtils.sol\":{\"keccak256\":\"0x253ef2d2e5d776377efadd51de645c8b07610c07fbc94a58f07942b514e20aa7\",\"urls\":[\"bzz-